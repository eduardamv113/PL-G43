C Testa operacoes aritmeticas basicas e numeros reais
      PROGRAM ARITMETICA
      REAL A, B, SOMA, DIFER, PROD, QUOC
      A = 10.5
      B = 3.0
      SOMA  = A + B
      DIFER = A - B
      PROD  = A * B
      QUOC  = A / B
      PRINT *, 'Soma:      ', SOMA
      PRINT *, 'Diferenca: ', DIFER
      PRINT *, 'Produto:   ', PROD
      PRINT *, 'Quociente: ', QUOC
      END
